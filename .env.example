# Discord bot token (Required)
BOT_TOKEN=

# Optional: Token for the status API. If left blank, the status page is open (no auth).
STATUS_TOKEN=

# Comma-separated allowed container names this bot may control (exact match)
ALLOWED_CONTAINERS=my_game_server

# Comma-separated role names that may perform control actions by default
DEFAULT_ALLOWED_ROLES=ServerAdmin

# Optional: Lock bot to a specific Discord Guild ID (Security)
DISCORD_GUILD_ID=

# Optional: Channel ID to send shutdown/restart announcements to.
# If left blank, announcements are sent to the channel where the command was typed.
ANNOUNCE_CHANNEL_ID=

# Optional: Role ID to mention (ping) during announcements.
ANNOUNCE_ROLE_ID=

# Optional: Comma-separated list of Channel IDs where commands are allowed.
# If left blank, the bot listens in all channels.
ALLOWED_CHANNEL_IDS=

# Template command to announce in-game. Use {message} placeholder.
# SECURITY: The {message} will be strictly sanitized (alphanumeric + basic punctuation only).
# screen -S my_game -p 0 -X stuff "say {message}\015"
CONTAINER_MESSAGE_CMD=screen -S my_game -p 0 -X stuff "say {message}\015"

# HTTP status port
STATUS_PORT=8000

# Shutdown delay in seconds (default 300 = 5 minutes)
SHUTDOWN_DELAY=300

# Logging level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO

# Max concurrent docker operations
DOCKER_MAX_WORKERS=2

# File path for storing permissions
PERMISSIONS_FILE=data/permissions.json

# File path for logging
LOG_FILE=data/bot.log

# Command cooldown in seconds (per-user rate limit, default 5)
COMMAND_COOLDOWN=5

# Crash alerting: how often (seconds) to poll container status (default 30)
CRASH_CHECK_INTERVAL=30

# Channel ID for crash alerts (0 = use ANNOUNCE_CHANNEL_ID, if that is also 0 no alerts are sent)
CRASH_ALERT_CHANNEL_ID=

# File path for command history / audit log
HISTORY_FILE=data/history.json
